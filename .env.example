APP_NAME=KnowledgeChat AI Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
OLLAMA_HOST=http://host.docker.internal:11434
CHAT_MODEL=gemma3:12b
CHAT_MAX_TOKENS=768
EMBEDDING_MODEL=nomic-embed-text
VECTOR_COLLECTION_NAME=knowledgechat
RETRIEVAL_CANDIDATE_K=30
CHAT_CONTEXT_MAX_CHUNKS=5
RETRIEVAL_MIN_SIMILARITY=0.65
OUT_OF_DOMAIN_MIN_SIMILARITY=0.70
OUT_OF_DOMAIN_MIN_LEXICAL_OVERLAP=0.12
OUT_OF_DOMAIN_MIN_GUIDE_CONFIDENCE=0.50
REQUEST_TIMEOUT=60
CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
